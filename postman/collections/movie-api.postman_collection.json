    {
      "name": "Register User",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const randomNum = Math.floor(Math.random() * 10000);",
              "const username = `user_${randomNum}`;",
              "",
              "pm.collectionVariables.set('random_user', username);",
              "",
              "pm.environment.set('random_user', username);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function() {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test(\"The anwswer has succeed message\", function() {",
              "    const response = pm.response.json();",
              "    pm.expect(response.message).to.equal('Usuario creado exitosamente');",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"username\": \"{{random_user}}\",\n    \"password\": \"123456\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/auth/register",
          "host": [
